# Try importing AI libraries
try:
    from ultralytics import YOLO
    YOLO_AVAILABLE = True
except ImportError:
    print("⚠️ YOLOv8 not available, using basic detection")
    YOLO_AVAILABLE = False

try:
    import easyocr
    OCR_AVAILABLE = True
except ImportError:
    print("⚠️ EasyOCR not available, OCR disabled")
